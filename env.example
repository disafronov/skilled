#
# Skilled — environment variables example
#
# Copy to `.env` (optional) and adjust values as needed.
# The application loads env vars via `os.getenv(...)`.
#

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------

# Debug mode. Set to False in production.
DJANGO_DEBUG=True

# Django secret key. Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=insecure-dev-key-change-in-production

# Comma-separated list of allowed hostnames/IPs.
# Use "*" only behind a trusted reverse proxy.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Security flags. Defaults are DEBUG-aware; set explicitly in production.
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0

# Admin superuser (created by `make run` and `make docker-run`).
# If set, the admin user is created automatically on startup.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=password

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------

# Optional policy file appended to every LLM SKILL + Wrapper combo.
# Missing or empty file means no global policy.
POLICY_FILE=policy.md

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Database connection settings.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=database
DATABASE_USER=user
DATABASE_PASSWORD=password

# -----------------------------------------------------------------------------
# Django Q2
# -----------------------------------------------------------------------------

# Task queue cluster name.
Q_CLUSTER_NAME=skilled
# Number of worker processes.
Q_WORKERS=2
# Task timeout in seconds.
Q_TIMEOUT=600
# Retry timeout in seconds (must be > Q_TIMEOUT).
Q_RETRY=660
# Maximum number of queued tasks.
Q_QUEUE_LIMIT=50
# Number of tasks to fetch in bulk.
Q_BULK=10

# -----------------------------------------------------------------------------
# Django Q2 task schedules (managed in code and overwritten in the DB)
# -----------------------------------------------------------------------------
# Values are minutes between runs.

# How often to poll Telegram for new messages.
Q2_TELEGRAM_INGEST_MINUTES=1

# How often to check for pending LLM jobs.
Q2_LLM_WORKER_MINUTES=1

# Requeue LLM jobs that were started but not finished after this many seconds.
Q2_LLM_STALE_JOB_SECONDS=3600

# How often to deliver completed responses to Telegram.
Q2_TELEGRAM_DELIVER_MINUTES=1

# How often to delete stale successful django-q2 task records.
Q2_SUCCESS_CLEANUP_MINUTES=60

# Delete successful django-q2 task records after this many seconds.
Q2_SUCCESS_TASK_RETENTION_SECONDS=86400
